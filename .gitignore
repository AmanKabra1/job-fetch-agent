# NEVER commit secrets
service_account.json
.env
# Vercel build config must be committed (no inline comments in .gitignore!)
*.json
!package.json
!vercel.json

# Python
__pycache__/
*.pyc
.venv/
venv/
env/

# Local output
*.csv
*.xlsx

# Dashboard cache + generated resumes. The daily job feed (data/jobs.json) IS
# committed — the cron writes it and the Vercel app reads it — so un-ignore just
# that one file (the negation also overrides the *.json rule above).
data/*
!data/jobs.json
resume/

# Vercel
.vercel/
