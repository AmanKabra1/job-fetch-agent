# Copy this file to ".env" and fill in your secrets. ".env" is gitignored.
# The app loads .env automatically on startup (set once, never re-type).

# Optional: Tavily AI web-search fallback (free key at https://tavily.com).
# Used only when the job boards return fewer results than requested.
TAVILY_API_KEY=

# Optional: Google service account JSON (single line) for the Sheet cron / Vercel.
# GOOGLE_CREDENTIALS=
